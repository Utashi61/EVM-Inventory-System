<%- include('../partials/head') %>
<% locals.activePage = 'equipment'; %>
<div class="app-layout">
  <%- include('../partials/ro-sidebar') %>
  <div class="main-content">
    <div class="topbar"><h1>✏️ Edit Equipment</h1></div>
    <div class="page-body">
      <%- include('../partials/flash') %>
      <div class="card" style="max-width:600px;">
        <div class="card-header"><h2>Edit Equipment Details</h2></div>
        <div class="card-body" style="padding:24px;">
          <form action="/ro/equipment/<%= equipment.id %>/edit" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Equipment Type <span class="required">*</span></label>
                <select name="equipment_type" id="equipment_type" class="form-control" required
                        onchange="updateSerialPrefix(this.value)">
                  <% ['Ballot Unit','Control Unit','Battery'].forEach(t => { %>
                  <option value="<%= t %>" <%= equipment.equipment_type === t ? 'selected' : '' %>><%= t %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Serial Number <span class="required">*</span></label>
                <div style="display:flex;align-items:center;gap:0;">
                  <span id="serial-prefix"
                        style="padding:8px 10px;background:#f0f4ff;border:1px solid #cbd5e1;border-right:none;border-radius:6px 0 0 6px;font-weight:700;color:#1E3A5F;font-size:13px;min-width:38px;text-align:center;">
                    <%= equipment.equipment_type === 'Ballot Unit' ? 'BU-' : equipment.equipment_type === 'Control Unit' ? 'CU-' : 'BT-' %>
                  </span>
                  <input type="text" name="serial_number" id="serial_number_input" class="form-control"
                         value="<%= equipment.serial_number.replace(/^(BU-|CU-|BT-)/i, '') %>"
                         required style="border-radius:0 6px 6px 0;border-left:none;">
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Status <span class="required">*</span></label>
              <select name="status" class="form-control" required>
                <option value="Functional"     <%= equipment.status === 'Functional'     ? 'selected' : '' %>>Functional</option>
                <option value="Non-Functional" <%= equipment.status === 'Non-Functional' ? 'selected' : '' %>>Non-Functional</option>
              </select>
            </div>
            <div class="form-actions" style="display:flex;gap:10px;align-items:center;">
              <button type="submit" class="btn btn-primary">💾 Update Equipment</button>
              <a href="/ro/equipment" class="btn btn-outline">Cancel</a>
              <form action="/ro/equipment/<%= equipment.id %>/delete" method="POST" style="margin:0;"
                    onsubmit="return confirm('Delete <%= equipment.serial_number %>? This cannot be undone.')">
                <button type="submit" class="btn btn-danger" style="background:#ef4444;border-color:#ef4444;">🗑 Delete</button>
              </form>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
<script>
const PREFIXES = {'Ballot Unit':'BU-','Control Unit':'CU-','Battery':'BT-'};
function updateSerialPrefix(type) { document.getElementById('serial-prefix').textContent = PREFIXES[type]||''; }
document.querySelector('form').addEventListener('submit', function() {
  const type = document.getElementById('equipment_type').value;
  const inp  = document.getElementById('serial_number_input');
  inp.value  = (PREFIXES[type]||'') + inp.value.trim().replace(/^(BU-|CU-|BT-)/i,'');
});
</script>
</body></html>
