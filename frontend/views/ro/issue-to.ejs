<%- include('../partials/head') %>
<% locals.activePage = 'issue-to'; %>

<div class="app-layout">
  <%- include('../partials/ro-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <h1>Issue To Presiding Officer</h1>
      <div class="topbar-actions">
        <button class="btn btn-primary btn-sm" onclick="openModal('modal-issue')">📤 Issue Equipment</button>
      </div>
    </div>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <!-- ── EQUIPMENT CURRENTLY AT POLLING STATIONS ─────────────── -->
      <% if (atPollingStations && atPollingStations.length > 0) { %>
      <%
        // Group by station
        const byStation = {};
        atPollingStations.forEach(e => {
          if (!byStation[e.station_id]) byStation[e.station_id] = { name: e.station_name, presiding_name: e.presiding_name, items: [] };
          byStation[e.station_id].items.push(e);
        });
      %>
      <div class="card" style="border-left:4px solid #f59e0b;">
        <div class="card-header">
          <h2>📍 Equipment at Polling Stations — Receive Back</h2>
          <span class="badge badge-warning"><%= atPollingStations.length %> item(s) out</span>
        </div>
        <div class="alert alert-info" style="margin:12px 16px 0;">
          ℹ️ Equipment listed here is currently at a Polling Station. When the Polling Station returns the equipment to you:
          <ol style="margin:8px 0 0 20px;font-size:13px;line-height:1.8;">
            <li><strong>Download</strong> the Receive-Back Form (Excel)</li>
            <li>Get the Presiding Officer's signature, then <strong>sign yourself</strong> as RO</li>
            <li><strong>Upload</strong> the signed form</li>
            <li>Click <strong>Confirm Received</strong> — equipment moves back to your inventory</li>
          </ol>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Polling Station</th>
                <th>Presiding Officer</th>
                <th>Serial No.</th>
                <th>Type</th>
                <th>Condition</th>
                <th style="text-align:center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <%
                let rowIdx = 0;
                Object.values(byStation).forEach(station => {
                  const count = station.items.length;
              %>
                <% station.items.forEach((eq, ei) => { %>
                <tr>
                  <% if (ei === 0) { %>
                  <td rowspan="<%= count %>" style="vertical-align:middle;font-weight:600;"><%= rowIdx + 1 %></td>
                  <td rowspan="<%= count %>" style="vertical-align:middle;"><strong><%= station.name %></strong></td>
                  <td rowspan="<%= count %>" style="vertical-align:middle;"><%= station.presiding_name || '—' %></td>
                  <% } %>
                  <td><strong><%= eq.serial_number %></strong></td>
                  <td><span class="badge badge-primary"><%= eq.equipment_type %></span></td>
                  <td><span class="badge <%= eq.status === 'Functional' ? 'badge-success' : 'badge-danger' %>"><%= eq.status %></span></td>
                  <% if (ei === 0) { %>
                  <td rowspan="<%= count %>" style="vertical-align:middle;text-align:center;white-space:nowrap;">
                    <a href="/ro/polling-stations/<%= station.items[0].station_id %>/receive-back-form"
                       class="btn btn-sm btn-success" style="display:block;margin-bottom:6px;font-size:12px;">
                      📥 Download Excel Form
                    </a>
                    <button class="btn btn-sm btn-outline" style="display:block;width:100%;margin-bottom:6px;font-size:12px;"
                            onclick="openReceiveBackUpload('<%= station.items[0].station_id %>')">
                      📤 Upload Signed
                    </button>
                    <form action="/ro/polling-stations/<%= station.items[0].station_id %>/confirm-receive-back"
                          method="POST">
                      <button type="submit" class="btn btn-sm btn-primary" style="display:block;width:100%;font-size:12px;"
                              onclick="return confirm('Confirm you received back all equipment from <%= station.name %>? They will move back into your inventory.')">
                        ✅ Confirm Received
                      </button>
                    </form>
                  </td>
                  <% } %>
                </tr>
                <% }) %>
              <% rowIdx++; }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <div class="alert alert-info">
        ℹ️ Issue equipment from your own inventory down to a Polling Station in
        <strong><%= currentUser.constituency_name %></strong>.
      </div>

      <!-- Issue History — grouped by date so one Form/Upload covers all equipment issued together -->
      <div class="card">
        <div class="card-header">
          <h2>Issue History — <%= currentUser.constituency_name %></h2>
          <small class="text-muted">Each row = all equipment issued on that date to that station — one Form covers the whole batch</small>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Date</th>
                <th>Polling Station</th>
                <th>Equipment Issued</th>
                <th>Items</th>
                <th>Status</th>
                <th>Forms</th>
              </tr>
            </thead>
            <tbody>
              <% if (!issueGroups || !issueGroups.length) { %>
              <tr><td colspan="7">
                <div class="empty-state">
                  <div class="empty-icon">📤</div>
                  <h3>No issues yet</h3>
                  <p>Use "Issue Equipment" to assign equipment to a Polling Station.</p>
                </div>
              </td></tr>
              <% } else { %>
                <% issueGroups.forEach((g, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= new Date(g.issue_date).toLocaleDateString() %></strong></td>
                  <td><%= g.polling_station_name %></td>
                  <td style="font-size:12px;">
                    <% (String(g.serials||'')).split(', ').forEach(s => { %>
                    <div style="margin:2px 0;"><span class="badge badge-primary"><%= s.trim() %></span></div>
                    <% }) %>
                  </td>
                  <td><%= g.item_count %></td>
                  <td><span class="badge <%= g.status === 'Received' ? 'badge-success' : 'badge-warning' %>"><%= g.status %></span></td>
                  <td style="white-space:nowrap;">
                    <%
                      const isoDate = String(g.issue_date || '').split('T')[0];
                      const stEnc   = encodeURIComponent(g.polling_station_name || '');
                    %>
                    <a href="/ro/issue-form?issue_date=<%= isoDate %>&station_name=<%= stEnc %>"
                       class="btn btn-sm btn-success" style="font-size:11px;padding:3px 8px;"
                       title="Download Excel Issue Receipt for all <%= g.item_count %> item(s) on this date">
                      📥 Excel Form
                    </a>
                    <button class="btn btn-sm btn-outline" style="font-size:11px;padding:3px 8px;margin-left:4px;"
                            onclick="openGroupUpload('<%= g.sample_transfer_id %>','issue')"
                            title="Upload signed form for this batch">
                      📤 Upload
                    </button>
                    <% if (g.form_uploaded) { %>
                    <span class="badge badge-success" style="font-size:10px;margin-left:4px;">✔ Signed</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Received Back History — grouped by date + station -->
      <% if (receivedBack && receivedBack.length > 0) { %>
      <div class="card" style="border-left:4px solid #22c55e;">
        <div class="card-header">
          <h2>✅ Received Back from Polling Stations</h2>
          <small class="text-muted">Equipment returned from Polling Stations to your inventory</small>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Date Received</th>
                <th>From Station</th>
                <th>Equipment</th>
                <th>Items</th>
                <th>Forms</th>
              </tr>
            </thead>
            <tbody>
              <% receivedBack.forEach((g, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= new Date(g.receive_date).toLocaleDateString() %></strong></td>
                <td><%= g.station_name || '—' %></td>
                <td style="font-size:12px;">
                  <% (String(g.serials||'')).split(', ').forEach(s => { %>
                  <div style="margin:2px 0;"><span class="badge badge-primary"><%= s.trim() %></span></div>
                  <% }) %>
                </td>
                <td><%= g.item_count %></td>
                <td style="white-space:nowrap;">
                  <button class="btn btn-sm btn-outline" style="font-size:11px;padding:3px 8px;"
                          onclick="openGroupUpload('<%= g.sample_transfer_id %>','receive_back')"
                          title="Upload signed Receive-Back form for this batch">
                    📤 Upload
                  </button>
                  <% if (g.form_uploaded) { %>
                  <span class="badge badge-success" style="font-size:10px;margin-left:4px;">✔ Signed</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>


<!-- Modal: Issue Equipment -->
<div id="modal-issue" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <h3>📤 Issue Equipment to Presiding Officer</h3>
      <button class="modal-close" onclick="closeModal('modal-issue')">✕</button>
    </div>
    <form action="/ro/issue-to" method="POST">

      <div class="form-group">
        <label class="form-label">Select Equipment <span class="required">*</span></label>
          <% if (equipment && equipment.length) { %>
            <div style="max-height:220px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:8px;padding:8px;">
              <% let lastType2=''; equipment.forEach(eq => {
                if(eq.equipment_type !== lastType2) { if(lastType2) { %></div><% }
              %><div style="font-weight:600;font-size:11px;color:var(--primary);text-transform:uppercase;margin:8px 0 4px;"><%= eq.equipment_type %></div>
              <div>
              <%   lastType2=eq.equipment_type; } %>
              <label style="display:flex;align-items:center;gap:8px;padding:4px 8px;border-radius:5px;cursor:pointer;" class="equip-check-row">
                <input type="checkbox" name="equipment_ids" value="<%= eq.id %>" class="equip-checkbox" data-type="<%= eq.equipment_type %>">
                <span><%= eq.serial_number %></span>
              </label>
              <% }) %></div>
            </div>
          <% } else { %>
            <p class="text-muted" style="margin:6px 0;">No functional equipment currently with you.</p>
          <% } %>
          <small class="text-muted" id="ro-selected-count">0 item(s) selected</small>
          <script>document.querySelectorAll('.equip-checkbox').forEach(cb=>cb.addEventListener('change',()=>{const n=document.querySelectorAll('.equip-checkbox:checked').length;document.getElementById('ro-selected-count').textContent=n+' item(s) selected';}));</script>
      </div>

      <div class="form-group">
        <label class="form-label">Polling Station <span class="required">*</span></label>
        <select name="polling_station_id" class="form-control" required>
          <option value="">-- Select Polling Station --</option>
          <% if (stations && stations.length) { %>
            <% stations.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.name %><% if(s.presiding_name){ %> — <%= s.presiding_name %><% } %><% if(s.gewog_name){ %> (<%= s.gewog_name %>)<% } %></option>
            <% }) %>
          <% } else { %>
            <option disabled>No Polling Stations registered in your Constituency yet. Add them via your DzEO.</option>
          <% } %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Remarks</label>
        <textarea name="remarks" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">📤 Issue Equipment</button>
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-issue')">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>

<!-- Modal: Upload Signed Form (Issue / Receive Back) -->
<div id="modal-upload-form" class="modal-overlay">
  <div class="modal" style="max-width:460px;">
    <div class="modal-header">
      <h3 id="upload-modal-title">📤 Upload Signed Form</h3>
      <button class="modal-close" onclick="closeModal('modal-upload-form')">✕</button>
    </div>
    <form id="upload-form-el" action="" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="issue_date"   id="upload-issue-date">
      <input type="hidden" name="station_name" id="upload-station">
      <div class="form-group">
        <label class="form-label">Signed File (Excel or Scanned PDF/Image) <span class="required">*</span></label>
        <input type="file" name="signed_form" class="form-control"
               accept=".pdf,application/pdf" required>
        <small class="text-muted">PDF only (max 10 MB). Scan or photograph the signed form and save as PDF before uploading.</small>
        <small class="text-muted">Accepted: .xlsx, .pdf, .jpg, .png (max 10 MB)</small>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">📤 Upload</button>
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-upload-form')">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
// openGroupUpload: called with sample_transfer_id and form_type ('issue' or 'receive_back')
function openGroupUpload(transferId, formType) {
  document.getElementById('upload-form-el').action = `/ro/transfers/${transferId}/upload/${formType}`;
  document.getElementById('upload-modal-title').textContent =
    formType === 'receive_back' ? '📤 Upload Signed Receive-Back Form' : '📤 Upload Signed Issue Form';
  openModal('modal-upload-form');
}
// Legacy single-transfer upload (issue history)
function openUploadModal(transferId, formType) {
  openGroupUpload(transferId, formType);
}
// Upload from "Equipment at Polling Stations" receive-back section
function openReceiveBackUpload(stationId) {
  document.getElementById('upload-form-el').action = `/ro/polling-stations/${stationId}/upload-receive-back`;
  document.getElementById('upload-modal-title').textContent = '📤 Upload Signed Receive-Back Form';
  openModal('modal-upload-form');
}
</script>
</body>
</html>
