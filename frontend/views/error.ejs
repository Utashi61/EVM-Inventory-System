<%- include('partials/head') %>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--bg);">
  <div style="text-align:center; padding:48px;">
    <div style="font-size:80px; margin-bottom:16px;"><%= code === 404 ? '🔍' : '⚠️' %></div>
    <h1 style="font-size:64px; font-weight:700; color:var(--primary); line-height:1;"><%= code %></h1>
    <h2 style="font-size:22px; color:#4a5568; margin:16px 0 8px;"><%= title %></h2>
    <p style="color:#718096; margin-bottom:32px;"><%= message %></p>
    <% if (locals.currentUser) { %>
      <% const dashMap = { Admin: '/admin/dashboard', DzEO: '/dzeo/dashboard', RO: '/ro/dashboard' }; %>
      <a href="<%= dashMap[currentUser.role] || '/login' %>" class="btn btn-primary">← Back to Dashboard</a>
    <% } else { %>
      <a href="/login" class="btn btn-primary">← Back to Login</a>
    <% } %>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
