<%- include('../partials/head') %>
<% locals.activePage = 'reports'; %>

<div class="app-layout">
  <%- include('../partials/admin-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <h1>Reports</h1>
    </div>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="card">
        <div class="card-header"><h2>📑 Generate Reports</h2></div>
        <div class="card-body">
          <div class="form-group">
            <label class="form-label">Filter by Dzongkhag (optional)</label>
            <select id="dzong-filter" class="form-control" style="max-width: 300px;">
              <option value="">All Dzongkhags</option>
              <% dzongkhags.forEach(dz => { %>
              <option value="<%= dz.id %>"><%= dz.name %></option>
              <% }) %>
            </select>
          </div>

          <h3 class="mt-2 mb-2" style="font-size:15px; color:var(--primary);">Equipment Reports</h3>
          <div class="report-options">
            <div class="report-card">
              <div class="report-icon">📦</div>
              <h4>Inventory Report</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">All equipment across all Dzongkhags</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a id="inv-pdf" href="#" class="btn btn-sm btn-danger" onclick="generateReport('inventory', 'pdf')">PDF</a>
                <a id="inv-excel" href="#" class="btn btn-sm btn-success" onclick="generateReport('inventory', 'excel')">Excel</a>
              </div>
            </div>
            <div class="report-card">
              <div class="report-icon">✅</div>
              <h4>Functional Equipment</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Only functional equipment</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="#" class="btn btn-sm btn-danger" onclick="generateReport('functional', 'pdf')">PDF</a>
                <a href="#" class="btn btn-sm btn-success" onclick="generateReport('functional', 'excel')">Excel</a>
              </div>
            </div>
            <div class="report-card">
              <div class="report-icon">❌</div>
              <h4>Non-Functional Equipment</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Only non-functional equipment</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="#" class="btn btn-sm btn-danger" onclick="generateReport('non_functional', 'pdf')">PDF</a>
                <a href="#" class="btn btn-sm btn-success" onclick="generateReport('non_functional', 'excel')">Excel</a>
              </div>
            </div>
          </div>

          <h3 class="mt-3 mb-2" style="font-size:15px; color:var(--primary);">Forms &amp; Templates</h3>
          <div class="report-options">
            <div class="report-card">
              <div class="report-icon">📋</div>
              <h4>Surrender Form Template</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Blank Excel template for Dzongkhag surrender documentation (CU/BU paired)</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="/admin/surrender/template" class="btn btn-sm btn-success">📥 Download Excel</a>
              </div>
            </div>
            <div class="report-card">
              <div class="report-icon">📤</div>
              <h4>Upload Surrender Records</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Bulk-import historical surrender records from a filled-in Excel file</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="/admin/surrender/upload" class="btn btn-sm btn-primary">📤 Upload Excel</a>
              </div>
            </div>
          </div>

          <h3 class="mt-3 mb-2" style="font-size:15px; color:var(--primary);">Transfer Reports</h3>
          <div class="report-options">
            <div class="report-card">
              <div class="report-icon">🔄</div>
              <h4>Transfer Report</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">All transfer records</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="#" class="btn btn-sm btn-danger" onclick="generateReport('transfer', 'pdf')">PDF</a>
                <a href="#" class="btn btn-sm btn-success" onclick="generateReport('transfer', 'excel')">Excel</a>
              </div>
            </div>
          </div>

          <h3 class="mt-3 mb-2" style="font-size:15px; color:var(--primary);">Functionality Check &amp; Surrender Reports</h3>
          <div class="report-options">
            <div class="report-card">
              <div class="report-icon">🗓️</div>
              <h4>Quarterly Functionality Check</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Functionality check history (every quarter)</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="#" class="btn btn-sm btn-danger" onclick="generateReport('quarterly_check', 'pdf')">PDF</a>
                <a href="#" class="btn btn-sm btn-success" onclick="generateReport('quarterly_check', 'excel')">Excel</a>
              </div>
            </div>
            <div class="report-card">
              <div class="report-icon">📮</div>
              <h4>Surrender Equipment</h4>
              <p class="text-muted" style="font-size:12px; margin:8px 0;">Equipment surrendered by Dzongkhags to HQ</p>
              <div class="flex gap-2 mt-1" style="justify-content:center;">
                <a href="#" class="btn btn-sm btn-danger" onclick="generateReport('surrender', 'pdf')">PDF</a>
                <a href="#" class="btn btn-sm btn-success" onclick="generateReport('surrender', 'excel')">Excel</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
function generateReport(type, format) {
  const dzong = document.getElementById('dzong-filter').value;
  let url = `/admin/reports/generate?report_type=${type}&format=${format}`;
  if (dzong) url += `&dzongkhag_id=${dzong}`;
  window.open(url, '_blank');
}
</script>
</body>
</html>