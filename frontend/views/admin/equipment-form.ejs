<%- include('../partials/head') %>
<% locals.activePage = equipment ? 'equipment' : 'equipment-add'; %>

<div class="app-layout">
  <%- include('../partials/admin-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <h1><%= equipment ? 'Edit Equipment' : 'Add New Equipment' %></h1>
      <div class="topbar-actions">
        <a href="/admin/equipment" class="btn btn-outline btn-sm">← Back to List</a>
      </div>
    </div>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="card" style="max-width: 680px;">
        <div class="card-header">
          <h2><%= equipment ? '✏️ Edit Equipment' : '➕ Add Equipment' %></h2>
        </div>
        <div class="card-body">
          <form action="/admin/equipment/<%= equipment ? equipment.id + '/edit' : 'add' %>" method="POST">

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Equipment Type <span class="required">*</span></label>
                <select name="equipment_type" id="equipment_type" class="form-control" required
                        onchange="updateSerialPrefix(this.value)">
                  <option value="">-- Select Type --</option>
                  <% ['Ballot Unit', 'Control Unit', 'Battery'].forEach(t => { %>
                  <option value="<%= t %>" <%= equipment && equipment.equipment_type === t ? 'selected' : '' %>><%= t %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Serial Number <span class="required">*</span></label>
                <div style="display:flex;align-items:center;gap:0;">
                  <span id="serial-prefix"
                        style="padding:8px 10px;background:#f0f4ff;border:1px solid #cbd5e1;border-right:none;border-radius:6px 0 0 6px;font-weight:700;color:#1E3A5F;font-size:13px;min-width:38px;text-align:center;">
                    <%= equipment ? (equipment.equipment_type === 'Ballot Unit' ? 'BU-' : equipment.equipment_type === 'Control Unit' ? 'CU-' : equipment.equipment_type === 'Battery' ? 'BT-' : '') : '' %>
                  </span>
                  <input type="text" name="serial_number" id="serial_number_input" class="form-control"
                         value="<%= equipment ? equipment.serial_number.replace(/^(BU-|CU-|BT-)/, '') : '' %>"
                         placeholder="e.g. 2232" required
                         style="border-radius:0 6px 6px 0;border-left:none;">
                  <input type="hidden" name="serial_number_full" id="serial_number_full">
                </div>
                <small class="text-muted">Select Equipment Type first — prefix (BU-, CU-, BT-) is added automatically.</small>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Location <span class="required">*</span></label>
                <select name="dzongkhag_id" id="isolated_dzongkhag" class="form-control" required
                        onchange="handleLocationChange(this.value)">
                  <option value="">-- Select Location --</option>
                  <option value="hq" <%= equipment && !equipment.dzongkhag_id ? 'selected' : '' %>>Thimphu HQ</option>
                  <% dzongkhags.filter(d => d.name !== 'Thimphu HQ').forEach(d => { %>
                  <option value="<%= d.id %>" <%= equipment && equipment.dzongkhag_id == d.id ? 'selected' : '' %>><%= d.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Equipment Status <span class="required">*</span></label>
                <select name="status" class="form-control" required>
                  <option value="Functional" <%= !equipment || equipment.status === 'Functional' ? 'selected' : '' %>>Functional</option>
                  <option value="Non-Functional" <%= equipment && equipment.status === 'Non-Functional' ? 'selected' : '' %>>Non-Functional</option>
                </select>
              </div>
            </div>

            <div class="form-group" id="hq-note" style="display:none;">
              <div class="alert alert-info" style="font-size:13px;margin:0;">
                ✅ Equipment will be stored at <strong>Thimphu HQ</strong> and assigned to Admin. Use Transfers to move it to a Dzongkhag later.
              </div>
            </div>

            <div class="form-group" id="assign-to-group" style="display:none;">
              <label class="form-label">Assign To (DzEO / DzERO / EA) <span class="required">*</span></label>
              <select name="assigned_to" id="assigned-to" class="form-control">
                <option value="">-- Select Location First --</option>
                <% if (typeof officers !== 'undefined' && officers && officers.length) { %>
                  <% officers.forEach(o => { %>
                  <option value="<%= o.id %>" <%= equipment && equipment.current_holder_id == o.id ? 'selected' : '' %>><%= o.full_name %> (<%= o.role %>)</option>
                  <% }) %>
                <% } %>
              </select>
              <small class="text-muted">No officer listed? Create one first under <a href="/admin/users" target="_blank">User Management</a>.</small>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">
                <%= equipment ? '💾 Update Equipment' : '➕ Add Equipment' %>
              </button>
              <a href="/admin/equipment" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
const PREFIXES = { 'Ballot Unit': 'BU-', 'Control Unit': 'CU-', 'Battery': 'BT-' };

function updateSerialPrefix(type) {
  document.getElementById('serial-prefix').textContent = PREFIXES[type] || '';
}

// Combine prefix + number on submit
document.querySelector('form').addEventListener('submit', function(e) {
  const type   = document.getElementById('equipment_type').value;
  const prefix = PREFIXES[type] || '';
  const inp    = document.getElementById('serial_number_input');
  if (!inp) return;
  const clean = inp.value.trim().replace(/^(BU-|CU-|BT-)/i, '');
  inp.name  = 'serial_number';
  inp.value = prefix + clean;
});

async function handleLocationChange(val) {
  const assignGroup = document.getElementById('assign-to-group');
  const hqNote      = document.getElementById('hq-note');
  const assignSel   = document.getElementById('assigned-to');

  if (!val || val === '') {
    assignGroup.style.display = 'none';
    hqNote.style.display = 'none';
    return;
  }
  if (val === 'hq') {
    assignGroup.style.display = 'none';
    hqNote.style.display = 'block';
    if (assignSel) assignSel.removeAttribute('required');
    return;
  }
  // Dzongkhag selected — show officer dropdown and load officers
  hqNote.style.display = 'none';
  assignGroup.style.display = 'block';
  if (assignSel) assignSel.setAttribute('required', 'required');
  await loadOfficersByDzongkhag(val, assignSel, null);
}

// On page load init state for edit mode
window.addEventListener('DOMContentLoaded', () => {
  const typeSel = document.getElementById('equipment_type');
  if (typeSel && typeSel.value) updateSerialPrefix(typeSel.value);
  const locSel = document.getElementById('isolated_dzongkhag');
  if (locSel && locSel.value) handleLocationChange(locSel.value);
});
</script>
</body>
</html>