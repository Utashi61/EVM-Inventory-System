<%- include('../partials/head') %>
<% locals.activePage = 'equipment'; %>

<div class="app-layout">
  <%- include('../partials/dzeo-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <h1>Equipment — <%= currentUser.dzongkhag_name %></h1>
      <div class="topbar-actions">
        <!-- REMOVED: Add Equipment button completely cleared -->
      </div>
    </div>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="alert alert-info" style="font-size:13px;">
        ℹ️ This list shows only equipment currently in your Dzongkhag's store — equipment issued out to an RO/Presiding Officer, or surrendered to HQ, no longer appears here.
      </div>

      <!-- No filter bar — equipment list is scoped to this Dzongkhag's store -->

      <div class="card">
        <div class="card-header">
          <h2>Equipment List</h2>
          <span class="text-muted">Total: <%= pagination.total %> records</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Serial Number</th>
                <th>Type</th>
                <th>Constituency</th>
                <th>Gewog</th>
                <th>Status</th>
                <th>Current Holder</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (equipment.length === 0) { %>
              <tr>
                <td colspan="8">
                  <div class="empty-state">
                    <div class="empty-icon">📦</div>
                    <h3>No equipment found</h3>
                    <!-- REMOVED: Add your first equipment contextual dynamic route link -->
                  </div>
                </td>
              </tr>
              <% } %>
              <% equipment.forEach((eq, i) => { %>
              <tr>
                <td><%= (pagination.page - 1) * pagination.limit + i + 1 %></td>
                <td><strong><%= eq.serial_number %></strong></td>
                <td><span class="badge badge-primary"><%= eq.equipment_type %></span></td>
                <td><%= eq.constituency_name || '—' %></td>
                <td><%= eq.gewog_name || '—' %></td>
                <td>
                  <span class="badge <%= eq.status === 'Functional' ? 'badge-success' : 'badge-danger' %>">
                    <%= eq.status %>
                  </span>
                </td>
                <td><%= eq.current_holder || 'Unassigned' %></td>
                <td>
                  <a href="/dzeo/equipment/<%= eq.id %>/edit" class="btn btn-sm btn-outline" title="Edit">✏️ Edit</a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <% if (pagination.pages > 1) { %>
        <div style="padding: 16px 24px; border-top: 1px solid #e2e8f0;">
          <div class="pagination">
            <% if (pagination.page > 1) { %>
              <a href="?page=<%= pagination.page - 1 %>">← Prev</a>
            <% } else { %>
              <span class="disabled">← Prev</span>
            <% } %>
            <% for (let p = 1; p <= pagination.pages; p++) { %>
              <% if (p === pagination.page) { %>
                <span class="active"><%= p %></span>
              <% } else { %>
                <a href="?page=<%= p %>"><%= p %></a>
              <% } %>
            <% } %>
            <% if (pagination.page < pagination.pages) { %>
              <a href="?page=<%= pagination.page + 1 %>">Next →</a>
            <% } else { %>
              <span class="disabled">Next →</span>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>