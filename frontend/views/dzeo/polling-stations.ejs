<%- include('../partials/head') %>
<% locals.activePage = 'polling-stations'; %>

<div class="app-layout">
  <%- include('../partials/dzeo-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <h1>Polling Stations — <%= currentUser.dzongkhag_name %></h1>
      <div class="topbar-actions">
        <button class="btn btn-primary btn-sm" onclick="openModal('modal-station')">📍 Add Polling Station</button>
      </div>
    </div>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="alert alert-info">
        ℹ️ Polling Stations sit below Gewog in the hierarchy: <strong>Dzongkhag → Constituency → Gewog → Polling Station</strong>.
        Add the polling stations that fall under your Dzongkhag's Constituencies and Gewogs.
      </div>

      <div class="card">
        <div class="card-header">
          <h2>Polling Station List</h2>
          <span class="text-muted">Total: <%= stations.length %> station(s)</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Polling Station</th>
                <th>Presiding Officer Name</th>
                <th>Constituency</th>
                <th>Gewog</th>
                <th>Added By</th>
                <th>Added On</th>
              </tr>
            </thead>
            <tbody>
              <% if (!stations || !stations.length) { %>
              <tr>
                <td colspan="7">
                  <div class="empty-state">
                    <div class="empty-icon">📍</div>
                    <h3>No polling stations added yet</h3>
                    <p>Use "Add Polling Station" to register one under a Constituency and Gewog.</p>
                  </div>
                </td>
              </tr>
              <% } else { %>
                <% stations.forEach((s, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= s.name %></strong></td>
                  <td><%= s.presiding_name || '—' %></td>
                  <td><%= s.constituency_name || '—' %></td>
                  <td><%= s.gewog_name || '—' %></td>
                  <td><%= s.created_by_name || '—' %></td>
                  <td><%= s.created_at ? new Date(s.created_at).toLocaleDateString() : '—' %></td>
                </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Add Polling Station -->
<div id="modal-station" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <h3>📍 Add Polling Station</h3>
      <button class="modal-close" onclick="closeModal('modal-station')">✕</button>
    </div>
    <form action="/dzeo/polling-stations" method="POST">
      <div class="form-group">
        <label class="form-label">Dzongkhag</label>
        <input type="text" class="form-control" value="<%= currentUser.dzongkhag_name %>" readonly>
      </div>

      <div class="form-group">
        <label class="form-label">Constituency <span class="required">*</span></label>
        <select name="constituency_id" id="constituency_id" class="form-control" required onchange="onConstituencyChange(this.value)">
          <option value="">-- Select Constituency --</option>
          <% if (constituencies && constituencies.length) { %>
            <% constituencies.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Gewog <span class="required">*</span></label>
        <select name="gewog_id" id="gewog_id" class="form-control" required>
          <option value="">-- Select Constituency First --</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Polling Station Name <span class="required">*</span></label>
        <input type="text" name="name" class="form-control" placeholder="e.g. Community Primary School" required>
      </div>

      <div class="form-group">
        <label class="form-label">Presiding Officer Name</label>
        <input type="text" name="presiding_name" class="form-control" placeholder="e.g. Kinley Wangchuk">
        <small class="text-muted">Name of the officer presiding over this polling station. Can be updated later.</small>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">📍 Add Polling Station</button>
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-station')">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
